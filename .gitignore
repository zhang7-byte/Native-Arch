# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# IDE / build caches not covered by the default template
.vs/
**/.gradle/
# Visual Studio "Open Folder" CMake output dir
/windows/out/
**/out/build/
# Flutter desktop ephemeral build outputs (engine DLLs/PDBs, generated configs)
**/Flutter/ephemeral/
**/flutter/ephemeral/
# Packaged installers / signing material (never publish these)
/installer/output/
*.keystore
*.jks
key.properties
